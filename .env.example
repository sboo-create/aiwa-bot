# Скопируй в .env и заполни своими значениями.
BOT_TOKEN=сюда_токен_от_BotFather
AIWA_TZ=Europe/Moscow
# Telegram chat id для служебных команд и алертов бота.
AIWA_ADMIN=сюда_Telegram_chat_id_администратора
AIWA_ANALYTICS_SALT=сюда_отдельная_случайная_строка_минимум_32_символа
# Внешний Disrupt Analytics. Доставка идёт через локальный durable outbox.
# AIWA_TRACTION_URL=https://stats.multitool.works/p/aiwa/events
# AIWA_TRACTION_TOKEN=сюда_write_only_token_модуля_aiwa
# Подпись Telegram Mini App действует сутки. Можно уменьшить после проверки UX.
AIWA_INIT_DATA_MAX_AGE_SECONDS=86400
# Только если mini app размещён на другом origin; через запятую, без wildcard.
# AIWA_ALLOWED_ORIGINS=https://miniapp.example.com

# === LLM-провайдер ===
# Вариант 1 (по умолчанию) — GigaChat (Сбер):
AIWA_PROVIDER=gigachat
GIGACHAT_CREDENTIALS=сюда_Authorization_key_из_кабинета_GigaChat
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2
# TLS проверяется по умолчанию. Для собственного CA укажи путь к PEM вместо отключения проверки.
# GIGACHAT_CA_BUNDLE_FILE=/path/to/ca.pem

# Вариант 2 — LiteLLM-прокси (раскомментируй и заполни, если используешь его):
# AIWA_PROVIDER=litellm
# LITELLM_URL=https://...
# LITELLM_KEY=...
# LITELLM_MODEL=...
# LITELLM_CA_BUNDLE_FILE=/path/to/ca.pem

# Вариант 3 — OpenRouter. Endpoint подставляется только при наличии ключа:
# AIWA_PROVIDER=openrouter
# OPENROUTER_API_KEY=...
# OPENROUTER_BASE_URL=https://proxy.example/v1
# OPENROUTER_TEXT_MODEL=deepseek/deepseek-v4-flash
# OPENROUTER_VISION_MODEL=google/gemini-3.1-flash-lite
# OPENROUTER_MODEL=organization/model-slug  # старое имя, поддерживается как alias для text
# Для чувствительных данных эти безопасные значения включены по умолчанию.
# OPENROUTER_ZDR=1
# OPENROUTER_DATA_COLLECTION=deny
# HTTP без TLS блокируется, поскольку раскрывает ключ и данные. Только для изолированного теста:
# AIWA_ALLOW_INSECURE_LLM_HTTP=0
# OPENROUTER_HTTP_REFERER=https://your-product.example
# OPENROUTER_APP_TITLE=AIWA

# === Голос: распознавание через Groq Whisper ===
# Только для голосовых сообщений. Без ключа голос игнорируется, текст работает.
GROQ_API_KEY=сюда_ключ_groq_gsk_...

# Распознавание голоса: salute | groq | auto (по умолчанию auto).
# auto = сначала SaluteSpeech (голосовые Telegram, формат ogg/opus), для webm из мини-аппа и при сбое — Groq.
AIWA_STT=auto
# SBER_SALUTE_AUTH_KEY — это ТОЛЬКО секрет; логин отдельно (по умолчанию gigacons)
SBER_SALUTE_AUTH_KEY=сюда_секрет_speech.giga.chat
# SBER_SALUTE_CLIENT=gigacons
SBER_SALUTE_RECOGNITION_MODEL=voice_messaging
# URL по умолчанию — speech.giga.chat. Для smartspeech.sber.ru задай эти три и SALUTE_SPEECH_SCOPE:
# SBER_SALUTE_OAUTH_URL=https://speech.giga.chat/v1/token
# SBER_SALUTE_RECOGNIZE_URL=https://speech.giga.chat/rest/v1/speech:recognize
# SBER_SALUTE_SYNTH_URL=https://speech.giga.chat/rest/v1/text:synthesize

# Ответ голосом на голосовое сообщение (текст приходит всегда). 0 — только текст.
AIWA_VOICE_REPLY=1
AIWA_TTS_VOICE=erm
AIWA_TTS_MAXCHARS=700

# Утренняя сводка отправляется ровно в выбранное пользователем время.
# Тяжёлая генерация начинается заранее и распределяется по этому окну:
AIWA_SUMMARY_PREPARE_MIN=10
AIWA_SUMMARY_PREPARE_SPREAD_MIN=20
# Быстрый sender для пика в выбранную минуту.
AIWA_BROADCAST_WORKERS=10
AIWA_BROADCAST_DELAY=0.05

# Доля AI-ответов с кнопками «Полезно / Не помогло»: 0.20 = примерно каждый пятый.
AIWA_FEEDBACK_SAMPLE_RATE=0.20
