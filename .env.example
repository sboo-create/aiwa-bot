# Скопируй в .env и заполни своими значениями.
BOT_TOKEN=сюда_токен_от_BotFather
AIWA_TZ=Europe/Moscow

# === LLM-провайдер ===
# Вариант 1 (по умолчанию) — GigaChat (Сбер):
AIWA_PROVIDER=gigachat
GIGACHAT_CREDENTIALS=сюда_Authorization_key_из_кабинета_GigaChat
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2

# Вариант 2 — LiteLLM-прокси (раскомментируй и заполни, если используешь его):
# AIWA_PROVIDER=litellm
# LITELLM_URL=https://...
# LITELLM_KEY=...
# LITELLM_MODEL=...

# === Голос: распознавание через Groq Whisper ===
# Только для голосовых сообщений. Без ключа голос игнорируется, текст работает.
GROQ_API_KEY=сюда_ключ_groq_gsk_...

# Распознавание голоса: salute | groq | auto (по умолчанию auto).
# auto = сначала SaluteSpeech (голосовые Telegram, формат ogg/opus), для webm из мини-аппа и при сбое — Groq.
AIWA_STT=auto
SBER_SALUTE_AUTH_KEY=сюда_ключ_speech.giga.chat
SBER_SALUTE_RECOGNITION_MODEL=voice_messaging
# URL по умолчанию — speech.giga.chat. Для smartspeech.sber.ru задай эти три и SALUTE_SPEECH_SCOPE:
# SBER_SALUTE_OAUTH_URL=https://speech.giga.chat/v1/token
# SBER_SALUTE_RECOGNIZE_URL=https://speech.giga.chat/rest/v1/speech:recognize
# SBER_SALUTE_SYNTH_URL=https://speech.giga.chat/rest/v1/text:synthesize

# Ответ голосом на голосовое сообщение (текст приходит всегда). 0 — только текст.
AIWA_VOICE_REPLY=1
AIWA_TTS_VOICE=Nec_24000
AIWA_TTS_MAXCHARS=700
